{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "./server",
    "outDir": "./server/dist",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "skipLibCheck": true
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules"]
}